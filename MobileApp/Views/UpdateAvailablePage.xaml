<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MobileApp.ViewModels"
             x:Class="MobileApp.Views.UpdateAvailablePage"
             x:DataType="viewmodels:UpdateAvailableViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1a1a1a">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20">
        
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,40,0,20">
            <Image Source="helmut_logo.png" 
                   HeightRequest="80"
                   WidthRequest="80"
                   HorizontalOptions="Center"/>
            
            <Label Text="{Binding Title}"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="White"/>
            
            <Label Text="{Binding Subtitle}"
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   TextColor="#999999"
                   Margin="0,0,0,10"/>
        </VerticalStackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20">
                
                <!-- Version Info Card -->
                <Border BackgroundColor="#2a2a2a"
                        StrokeThickness="0"
                        Padding="20"
                        StrokeShape="RoundRectangle 12">
                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="12">
                        
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Current Version"
                               FontSize="12"
                               TextColor="#999999"/>
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="{Binding CurrentVersion}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="White"/>
                        
                        <BoxView Grid.Row="1" Grid.ColumnSpan="2"
                                 HeightRequest="1"
                                 Color="#3a3a3a"/>
                        
                        <Label Grid.Row="2" Grid.Column="0"
                               Text="Latest Version"
                               FontSize="12"
                               TextColor="#999999"/>
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding LatestVersion}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#4CAF50"/>
                    </Grid>
                </Border>

                <!-- What's New Section -->
                <VerticalStackLayout Spacing="10" IsVisible="{Binding HasFeatures}">
                    <Label Text="What's New"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    
                    <Border BackgroundColor="#2a2a2a"
                            StrokeThickness="0"
                            Padding="15"
                            StrokeShape="RoundRectangle 12">
                        <CollectionView ItemsSource="{Binding Features}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="0,5">
                                        <Label Grid.Column="0" 
                                               Text="•" 
                                               TextColor="#4CAF50"
                                               FontSize="16"
                                               VerticalOptions="Start"/>
                                        <Label Grid.Column="1" 
                                               Text="{Binding .}"
                                               TextColor="#CCCCCC"
                                               FontSize="14"
                                               LineBreakMode="WordWrap"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>
                </VerticalStackLayout>

                <!-- Download Progress -->
                <VerticalStackLayout Spacing="10" IsVisible="{Binding IsDownloading}">
                    <Label Text="Downloading Update..."
                           FontSize="14"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                    
                    <ProgressBar Progress="{Binding DownloadProgress}"
                                 ProgressColor="#4CAF50"
                                 HeightRequest="8"/>
                    
                    <Label Text="{Binding DownloadProgressText}"
                           FontSize="12"
                           TextColor="#999999"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- File Size Info -->
                <Label Text="{Binding FileSizeText}"
                       FontSize="12"
                       TextColor="#999999"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding ShowFileSize}"/>

                <!-- Mandatory Update Warning -->
                <Border BackgroundColor="#FF5722"
                        StrokeThickness="0"
                        Padding="15"
                        StrokeShape="RoundRectangle 8"
                        IsVisible="{Binding IsMandatory}">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="⚠️"
                               FontSize="20"
                               VerticalOptions="Center"/>
                        <Label Text="This is a critical update and must be installed to continue using the app."
                               TextColor="White"
                               FontSize="13"
                               LineBreakMode="WordWrap"
                               VerticalOptions="Center"
                               HorizontalOptions="FillAndExpand"/>
                    </HorizontalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Action Buttons -->
        <VerticalStackLayout Grid.Row="2" Spacing="12" Margin="0,20,0,10">
            
            <Button Text="{Binding UpdateButtonText}"
                    Command="{Binding DownloadUpdateCommand}"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    HeightRequest="50"
                    CornerRadius="8"
                    IsEnabled="{Binding IsNotDownloading}"/>
            
            <Button Text="View Release Notes"
                    Command="{Binding ViewReleaseNotesCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#4CAF50"
                    BorderColor="#4CAF50"
                    BorderWidth="1"
                    FontSize="14"
                    HeightRequest="45"
                    CornerRadius="8"
                    IsVisible="{Binding HasReleaseNotes}"
                    IsEnabled="{Binding IsNotDownloading}"/>
            
            <Button Text="Remind Me Later"
                    Command="{Binding RemindLaterCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#999999"
                    FontSize="14"
                    HeightRequest="40"
                    IsVisible="{Binding CanSkip}"
                    IsEnabled="{Binding IsNotDownloading}"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>