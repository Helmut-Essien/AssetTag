<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MobileApp.ViewModels"
             xmlns:controls="clr-namespace:MobileApp.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="MobileApp.MainPage"
             x:DataType="vm:MainPageViewModel"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="Auto,*">
        
        <!-- Clean Header Section - Material Design 3 -->
        <Grid Grid.Row="0"
              BackgroundColor="#005A9C"
              Padding="20,15,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Title -->
            <VerticalStackLayout Grid.Row="0" Grid.Column="0"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <Label Text="Asset Management"
                       FontFamily="OpenSansRegular"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"/>
                <Label Text="Field Operations"
                       FontFamily="OpenSansRegular"
                       FontSize="12"
                       TextColor="White"
                       Opacity="0.8"/>
            </VerticalStackLayout>
            
            <!-- Settings Icon Button -->
            <Border Grid.Row="0" Grid.Column="1"
                    BackgroundColor="Transparent"
                    Stroke="Transparent"
                    Padding="8"
                    VerticalOptions="Center"
                    HorizontalOptions="End">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Image WidthRequest="24" HeightRequest="24"
                       HorizontalOptions="Center"
                       VerticalOptions="Center">
                    <Image.Source>
                        <FontImageSource FontFamily="MaterialRegular"
                                       Glyph="{mi:Material Icon=Settings}"
                                       Color="White"
                                       Size="24"/>
                    </Image.Source>
                </Image>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateToSettingsCommand}"/>
                </Border.GestureRecognizers>
            </Border>
        </Grid>

        <!-- Main Content Area with Pull-to-Refresh -->
        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding RefreshCommand}"
                     RefreshColor="#005A9C">
            <ScrollView>
                <Grid>
                    <!-- Skeleton Loaders (visible while loading) -->
                    <VerticalStackLayout Spacing="24" Padding="20,20,20,20" IsVisible="{Binding IsBusy}">
                        
                        <!-- Summary Cards Skeleton -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                            <controls:SkeletonLoader Grid.Column="0" Type="StatCard"/>
                            <controls:SkeletonLoader Grid.Column="1" Type="StatCard"/>
                            <controls:SkeletonLoader Grid.Column="2" Type="StatCard"/>
                        </Grid>
                        
                        <!-- Sync Status Skeleton -->
                        <controls:SkeletonLoader Type="Card"/>
                        
                        <!-- Quick Actions Skeleton -->
                        <VerticalStackLayout Spacing="16">
                            <BoxView BackgroundColor="#E0E0E0" HeightRequest="18" WidthRequest="120" CornerRadius="4"/>
                            <controls:SkeletonLoader Type="Card"/>
                            <controls:SkeletonLoader Type="Card"/>
                            <controls:SkeletonLoader Type="Card"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Actual Content (visible when loaded) -->
                    <VerticalStackLayout Spacing="24" Padding="20,20,20,20" IsVisible="{Binding IsNotBusy}">
                    
                    <!-- Summary Cards Section -->
                    <Grid ColumnDefinitions="*,*,*"
                          ColumnSpacing="12">
                        
                        <!-- Total Assets Card -->
                        <Border Grid.Column="0"
                                BackgroundColor="White"
                                Stroke="Transparent"
                                Padding="12,16"
                                Shadow="{Shadow Brush=Black, Opacity=0.06, Radius=8, Offset='0,2'}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Image WidthRequest="28" HeightRequest="28" HorizontalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource FontFamily="MaterialRegular"
                                                       Glyph="{mi:Material Icon=Inventory}"
                                                       Color="#005A9C"
                                                       Size="28"/>
                                    </Image.Source>
                                </Image>
                                <Label Text="{Binding TotalAssets}"
                                       FontFamily="OpenSansRegular"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#333333"/>
                                <Label Text="Total Assets"
                                       FontFamily="OpenSansRegular"
                                       FontSize="11"
                                       HorizontalOptions="Center"
                                       TextColor="#666666"/>
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Scanned Today Card -->
                        <Border Grid.Column="1"
                                BackgroundColor="White"
                                Stroke="Transparent"
                                Padding="12,16"
                                Shadow="{Shadow Brush=Black, Opacity=0.06, Radius=8, Offset='0,2'}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Image WidthRequest="28" HeightRequest="28" HorizontalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource FontFamily="MaterialRegular"
                                                       Glyph="{mi:Material Icon=QrCodeScanner}"
                                                       Color="#4CAF50"
                                                       Size="28"/>
                                    </Image.Source>
                                </Image>
                                <Label Text="{Binding ScannedToday}"
                                       FontFamily="OpenSansRegular"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#333333"/>
                                <Label Text="Scanned Today"
                                       FontFamily="OpenSansRegular"
                                       FontSize="11"
                                       HorizontalOptions="Center"
                                       TextColor="#666666"/>
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Pending Sync Card -->
                        <Border Grid.Column="2"
                                BackgroundColor="White"
                                Stroke="Transparent"
                                Padding="12,16"
                                Shadow="{Shadow Brush=Black, Opacity=0.06, Radius=8, Offset='0,2'}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Image WidthRequest="28" HeightRequest="28" HorizontalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource FontFamily="MaterialRegular"
                                                       Glyph="{mi:Material Icon=SyncProblem}"
                                                       Color="#FFC107"
                                                       Size="28"/>
                                    </Image.Source>
                                </Image>
                                <Label Text="{Binding PendingSync}"
                                       FontFamily="OpenSansRegular"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#FFC107"/>
                                <Label Text="Pending Sync"
                                       FontFamily="OpenSansRegular"
                                       FontSize="11"
                                       HorizontalOptions="Center"
                                       TextColor="#666666"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                    
                    <!-- Sync Status Section -->
                    <Border BackgroundColor="White"
                            Stroke="Transparent"
                            Padding="20,24"
                            Shadow="{Shadow Brush=Black, Opacity=0.06, Radius=8, Offset='0,2'}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                            <Label Text="{Binding LastSync, StringFormat='Last Sync: {0}'}"
                                   FontFamily="OpenSansRegular"
                                   FontSize="14"
                                   HorizontalOptions="Center"
                                   TextColor="#666666"/>
                            
                            <!-- Sync Data Button -->
                            <Border BackgroundColor="#00796B"
                                    Stroke="Transparent"
                                    Padding="32,14"
                                    HorizontalOptions="Center"
                                    MinimumWidthRequest="200">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                                    <!-- Progress Indicator (visible when syncing) -->
                                    <ActivityIndicator Grid.Column="0"
                                                     IsRunning="{Binding IsSyncing}"
                                                     IsVisible="{Binding IsSyncing}"
                                                     Color="White"
                                                     WidthRequest="20"
                                                     HeightRequest="20"
                                                     VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="Sync Data"
                                           FontFamily="OpenSansRegular"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalOptions="Center"/>
                                </Grid>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SyncDataCommand}"/>
                                </Border.GestureRecognizers>
                            </Border>
                            
                            <!-- Progress Bar (visible when syncing) -->
                            <VerticalStackLayout Spacing="8"
                                               IsVisible="{Binding IsSyncing}"
                                               HorizontalOptions="Center"
                                               MinimumWidthRequest="250">
                                <ProgressBar Progress="{Binding SyncProgress}"
                                           ProgressColor="#00796B"
                                           HeightRequest="6"
                                           HorizontalOptions="FillAndExpand"/>
                                <Label Text="{Binding SyncStatusText}"
                                       FontFamily="OpenSansRegular"
                                       FontSize="12"
                                       HorizontalOptions="Center"
                                       TextColor="#666666"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Quick Actions Section -->
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Quick Actions"
                               FontFamily="OpenSansRegular"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#333333"
                               Margin="0,0,0,4"/>
                        
                        <!-- Add Asset Button -->
                        <Border BackgroundColor="White"
                                Stroke="Transparent"
                                Padding="20,18"
                                Shadow="{Shadow Brush=Black, Opacity=0.06, Radius=8, Offset='0,2'}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                <Border Grid.Column="0"
                                        BackgroundColor="#E8F5E9"
                                        WidthRequest="48"
                                        HeightRequest="48"
                                        Stroke="Transparent">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="24"/>
                                    </Border.StrokeShape>
                                    <Image WidthRequest="24" HeightRequest="24"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center">
                                        <Image.Source>
                                            <FontImageSource FontFamily="MaterialRegular"
                                                           Glyph="{mi:Material Icon=AddCircle}"
                                                           Color="#4CAF50"
                                                           Size="24"/>
                                        </Image.Source>
                                    </Image>
                                </Border>
                                
                                <VerticalStackLayout Grid.Column="1"
                                                   VerticalOptions="Center"
                                                   Spacing="2">
                                    <Label Text="Add New Asset"
                                           FontFamily="OpenSansRegular"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#333333"/>
                                    <Label Text="Register a new item into the inventory"
                                           FontFamily="OpenSansRegular"
                                           FontSize="13"
                                           TextColor="#666666"/>
                                </VerticalStackLayout>
                                
                                <Image Grid.Column="2"
                                       WidthRequest="28"
                                       HeightRequest="28"
                                       VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource FontFamily="MaterialRegular"
                                                       Glyph="{mi:Material Icon=ChevronRight}"
                                                       Color="#CCCCCC"
                                                       Size="28"/>
                                    </Image.Source>
                                </Image>
                            </Grid>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding AddAssetCommand}"/>
                            </Border.GestureRecognizers>
                        </Border>
                        
                        <!-- View Assets Button -->
                        <Border BackgroundColor="White"
                                Stroke="Transparent"
                                Padding="20,18"
                                Shadow="{Shadow Brush=Black, Opacity=0.06, Radius=8, Offset='0,2'}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                <Border Grid.Column="0"
                                        BackgroundColor="#E3F2FD"
                                        WidthRequest="48"
                                        HeightRequest="48"
                                        Stroke="Transparent">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="24"/>
                                    </Border.StrokeShape>
                                    <Image WidthRequest="24" HeightRequest="24"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center">
                                        <Image.Source>
                                            <FontImageSource FontFamily="MaterialRegular"
                                                           Glyph="{mi:Material Icon=ListAlt}"
                                                           Color="#005A9C"
                                                           Size="24"/>
                                        </Image.Source>
                                    </Image>
                                </Border>
                                
                                <VerticalStackLayout Grid.Column="1"
                                                   VerticalOptions="Center"
                                                   Spacing="2">
                                    <Label Text="View Asset List"
                                           FontFamily="OpenSansRegular"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#333333"/>
                                    <Label Text="Browse and filter existing inventory"
                                           FontFamily="OpenSansRegular"
                                           FontSize="13"
                                           TextColor="#666666"/>
                                </VerticalStackLayout>
                                
                                <Image Grid.Column="2"
                                       WidthRequest="28"
                                       HeightRequest="28"
                                       VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource FontFamily="MaterialRegular"
                                                       Glyph="{mi:Material Icon=ChevronRight}"
                                                       Color="#CCCCCC"
                                                       Size="28"/>
                                    </Image.Source>
                                </Image>
                            </Grid>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ViewAssetsCommand}"/>
                            </Border.GestureRecognizers>
                        </Border>
                        
                        <!-- Scan Asset Button -->
                        <Border BackgroundColor="White"
                                Stroke="Transparent"
                                Padding="20,18"
                                Shadow="{Shadow Brush=Black, Opacity=0.06, Radius=8, Offset='0,2'}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                <Border Grid.Column="0"
                                        BackgroundColor="#FFF3E0"
                                        WidthRequest="48"
                                        HeightRequest="48"
                                        Stroke="Transparent">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="24"/>
                                    </Border.StrokeShape>
                                    <Image WidthRequest="24" HeightRequest="24"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center">
                                        <Image.Source>
                                            <FontImageSource FontFamily="MaterialRegular"
                                                           Glyph="{mi:Material Icon=QrCodeScanner}"
                                                           Color="#FF9800"
                                                           Size="24"/>
                                        </Image.Source>
                                    </Image>
                                </Border>
                                
                                <VerticalStackLayout Grid.Column="1"
                                                   VerticalOptions="Center"
                                                   Spacing="2">
                                    <Label Text="Scan Asset"
                                           FontFamily="OpenSansRegular"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#333333"/>
                                    <Label Text="Quick lookup via barcode or QR"
                                           FontFamily="OpenSansRegular"
                                           FontSize="13"
                                           TextColor="#666666"/>
                                </VerticalStackLayout>
                                
                                <Image Grid.Column="2"
                                       WidthRequest="28"
                                       HeightRequest="28"
                                       VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource FontFamily="MaterialRegular"
                                                       Glyph="{mi:Material Icon=ChevronRight}"
                                                       Color="#CCCCCC"
                                                       Size="28"/>
                                    </Image.Source>
                                </Image>
                            </Grid>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ScanAssetCommand}"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </VerticalStackLayout>
                    
                    </VerticalStackLayout>
                </Grid>
            </ScrollView>
        </RefreshView>

        <!-- Sync Overlay - Blocks all interaction during sync -->
        <Grid Grid.RowSpan="2"
              IsVisible="{Binding IsSyncing}"
              BackgroundColor="#CC000000"
              InputTransparent="False">
            <VerticalStackLayout Spacing="24"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Padding="40">
                <Border BackgroundColor="White"
                        Stroke="Transparent"
                        Padding="40,50"
                        HorizontalOptions="Center"
                        Shadow="{Shadow Brush=Black, Opacity=0.3, Radius=20, Offset='0,4'}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="24" HorizontalOptions="Center">
                        <!-- Sync Icon -->
                        <Image WidthRequest="64" HeightRequest="64" HorizontalOptions="Center">
                            <Image.Source>
                                <FontImageSource FontFamily="MaterialRegular"
                                               Glyph="{mi:Material Icon=Sync}"
                                               Color="#00796B"
                                               Size="64"/>
                            </Image.Source>
                            <Image.Behaviors>
                                <toolkit:IconTintColorBehavior TintColor="#00796B"/>
                            </Image.Behaviors>
                        </Image>
                        
                        <!-- Syncing Text -->
                        <Label Text="Syncing Data"
                               FontFamily="OpenSansRegular"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="#333333"/>
                        
                        <!-- Progress Bar -->
                        <VerticalStackLayout Spacing="12" MinimumWidthRequest="280">
                            <ProgressBar Progress="{Binding SyncProgress}"
                                       ProgressColor="#00796B"
                                       HeightRequest="8"
                                       HorizontalOptions="FillAndExpand"/>
                            <Label Text="{Binding SyncStatusText}"
                                   FontFamily="OpenSansRegular"
                                   FontSize="14"
                                   HorizontalOptions="Center"
                                   TextColor="#666666"/>
                        </VerticalStackLayout>
                        
                        <!-- Activity Indicator -->
                        <ActivityIndicator IsRunning="{Binding IsSyncing}"
                                         Color="#00796B"
                                         WidthRequest="32"
                                         HeightRequest="32"
                                         HorizontalOptions="Center"/>
                        
                        <!-- Please Wait Message -->
                        <Label Text="Please wait while we sync your data"
                               FontFamily="OpenSansRegular"
                               FontSize="13"
                               HorizontalOptions="Center"
                               TextColor="#999999"
                               MaximumWidthRequest="280"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>

    </Grid>

</ContentPage>
